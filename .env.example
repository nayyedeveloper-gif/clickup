APP_NAME="29 Management"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=task_management
DB_USERNAME=root
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Use `reverb` for real-time chat (run `php artisan reverb:start` alongside `php artisan serve`).
# Use `log` or `null` only when debugging without WebSockets.
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=app-id
REVERB_APP_KEY=app-key
REVERB_APP_SECRET=app-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
# Must match REVERB_SCHEME (http = ws locally; https = wss). Browse the app via APP_URL / artisan serve so /broadcasting/auth works.
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
QUEUE_CONNECTION=sync
MAIL_USERNAME=nayye.developer@gmail.com
MAIL_PASSWORD=cbbcmxtkciyxmjmc
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=nayye.developer@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# Avatars & chat files: `local` (storage/app/public) or `s3` with AWS_* below.
FILESYSTEM_PUBLIC_DRIVER=local

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-north-1
AWS_BUCKET=clickup-854209350046-eu-north-1-an
# Required for public URLs when using S3 (virtual-hosted style for eu-north-1):
# AWS_URL=https://clickup-854209350046-eu-north-1-an.s3.eu-north-1.amazonaws.com
AWS_URL=
# Optional prefix inside the bucket (no leading slash)
# AWS_BUCKET_ROOT=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

REVERB_APP_ID=managers
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret

VITE_REVERB_APP_ID=managers
VITE_REVERB_HOST=managers.29jewellery.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
VITE_REVERB_APP_KEY=local-key
VITE_REVERB_APP_SECRET=local-secret

# Google OAuth
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

REVERB_SERVER_HOST=127.0.0.1
REVERB_SERVER_PORT=8080
