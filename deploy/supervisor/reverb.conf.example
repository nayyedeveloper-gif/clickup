# Adjust paths if your deploy directory differs (EC2 guide uses /var/www/29-management).
[program:reverb]
process_name=%(program_name)s
command=php /var/www/29-management/artisan reverb:start
directory=/var/www/29-management
autostart=true
autorestart=true
stopasgroup=true
killasgroup=true
user=www-data
numprocs=1
redirect_stderr=true
stdout_logfile=/var/www/29-management/storage/logs/reverb.log
stopwaitsecs=3600
