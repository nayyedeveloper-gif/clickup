# Copy values into server `.env` (never commit real secrets).
# APP_URL must match the URL users open in the browser (HTTPS in production).

APP_NAME="Project Management"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.example.com

# If you only have an EC2 public IP (HTTP, before TLS): use http://YOUR_IP and set:
# SESSION_SECURE_COOKIE=false
# See deploy/EC2_AWS_SETUP.md and deploy/nginx/laravel-http-ip.example.conf
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=

CACHE_STORE=database
QUEUE_CONNECTION=database

# Broadcasting — required for chat / Echo
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=

# Where the Reverb *process* listens (internal)
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# What browsers & Laravel use to reach Reverb (often nginx TLS → 8080)
# Option A — websocket subdomain (recommended)
REVERB_HOST=reverb.example.com
REVERB_PORT=443
REVERB_SCHEME=https

# Option B — same host as APP_URL; nginx proxies /app and /apps → Reverb
# REVERB_HOST=app.example.com
# REVERB_PORT=443
# REVERB_SCHEME=https

# Build-time (npm run build); must match REVERB_* above
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# IAM: s3:PutObject, s3:GetObject, s3:DeleteObject on the bucket (and prefix if AWS_BUCKET_ROOT is set).
# S3 CORS: allow GET from APP_URL if the browser loads avatars/attachments directly from the bucket URL.
FILESYSTEM_DISK=local
# Avatars & message attachments: use S3 in production (Stockholm / eu-north-1).
FILESYSTEM_PUBLIC_DRIVER=s3

# Leave empty if the EC2 instance has an IAM role with S3 access (recommended).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-north-1
AWS_BUCKET=clickup-854209350046-eu-north-1-an
# Public object URL base (or your CloudFront distribution URL)
AWS_URL=https://clickup-854209350046-eu-north-1-an.s3.eu-north-1.amazonaws.com
# AWS_BUCKET_ROOT=production
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Web Push (optional) — generate VAPID keys per Laravel Web Push docs
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
